# RL Trading System — API Keys Configuration
# Copy this file to .env and fill in your keys
# Usage: from dotenv import load_dotenv; load_dotenv()

# ── Market Data ────────────────────────────────────────────────────────────────
# Polygon.io: https://polygon.io/dashboard (free tier: 5 calls/min, 2yr history)
POLYGON_API_KEY=

# ── News & Sentiment ───────────────────────────────────────────────────────────
# Finnhub: https://finnhub.io/register (free tier: 60 calls/min)
FINNHUB_KEY=

# NewsAPI: https://newsapi.org/register (free tier: 100 calls/day)
NEWS_API_KEY=

# ── Alternative Data ───────────────────────────────────────────────────────────
# Alpha Vantage: https://www.alphavantage.co/support/#api-key (free)
ALPHA_VANTAGE_KEY=

# ── Execution (Phase 4 only) ──────────────────────────────────────────────────
# Alpaca: https://alpaca.markets (paper trading free, real trading requires approval)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2  # paper trading endpoint

# ── Experiment Tracking ────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=logs/mlruns

# ── Environment ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
